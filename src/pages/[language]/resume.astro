---
import Base from '@/layouts/Base.astro';
import { Icon } from 'astro-icon/components';
import { languages, useTranslations, type LanguageKey } from '@/i18n/i18n.ts';
import { getEntry } from 'astro:content';
import ModernResume from '@/components/resume/ModernResume.astro';
import TraditionalResume from '@/components/resume/TraditionalResume.astro';

const currentLocale = Astro.currentLocale as LanguageKey;
const t = useTranslations(currentLocale as LanguageKey);
const resume = (await getEntry('resume', currentLocale))?.data;
if (!resume) throw new Error('Resume Data is not found')
const currentTime = new Date()
  .toLocaleDateString('zh-TW', { year: 'numeric', month: '2-digit', day: '2-digit' })
  .replace(/\//g, '-');

export function getStaticPaths() {
  return Object.keys(languages).map((language) => ({
    params: { language },
  }));
}
---
<Base title={t('Resume-1')}>
<div style="padding-top: var(--navbar-height)" class='pb-16 flex flex-col gap-8 md:gap-12'>
  
  <!-- Tab Toggle UI -->
  <div class="sticky z-10 container mx-auto flex justify-center px-4 md:px-0 print:hidden" style="top: 1rem">
    <div class="flex gap-2 p-1 bg-primary-100 rounded-full shadow-sm backdrop-blur-md bg-opacity-90">
      <button 
        id="tab-modern" 
        class="resume-tab-btn px-6 py-2 rounded-full text-sm font-medium transition-all hover:text-primary-900 bg-white shadow-sm text-primary-900"
        onclick="switchResumeTab('modern')"
      >
        {t('Modern')}
      </button>
      <button 
        id="tab-traditional" 
        class="resume-tab-btn px-6 py-2 rounded-full text-sm font-medium transition-all text-primary-600 hover:text-primary-900"
        onclick="switchResumeTab('traditional')"
      >
        {t('Traditional')}
      </button>
    </div>
  </div>

  <!-- Resume Containers -->
  <div id="resume-wrapper">
    <div id="resume-modern" class="resume-content">
      <ModernResume {resume} {t} {currentTime} />
    </div>
    
    <div id="resume-traditional" class="resume-content hidden print:hidden">
      <TraditionalResume {resume} {t} {currentTime} />
    </div>
  </div>

  <button type="button" onclick="window.print()" class="cursor-pointer print:hidden flex border rounded-full transition-colors md:p-8 p-4 flex-wrap justify-center items-center gap-4 hover:bg-primary-800 hover:text-white mx-auto">
    <Icon size={48} name="material-symbols:sim-card-download-outline-rounded" />
    <span class="md:text-2xl text-xl font-medium">{t('Resume-6')}</span>
  </button>

</div>
</Base>

<script is:inline>
  function switchResumeTab(tab) {
    const btnModern = document.getElementById('tab-modern');
    const btnTrad = document.getElementById('tab-traditional');
    const contentModern = document.getElementById('resume-modern');
    const contentTrad = document.getElementById('resume-traditional');
    
    // For primary Tailwind colors used in base site
    const activeClasses = ['bg-white', 'shadow-sm', 'text-primary-900'];
    const inactiveTextClass = 'text-primary-600';
    
    if (tab === 'modern') {
      btnModern.classList.add(...activeClasses);
      btnModern.classList.remove(inactiveTextClass);
      
      btnTrad.classList.remove(...activeClasses);
      btnTrad.classList.add(inactiveTextClass);
      
      contentModern.classList.remove('hidden', 'print:hidden');
      contentTrad.classList.add('hidden', 'print:hidden');
    } else {
      btnTrad.classList.add(...activeClasses);
      btnTrad.classList.remove(inactiveTextClass);
      
      btnModern.classList.remove(...activeClasses);
      btnModern.classList.add(inactiveTextClass);
      
      contentTrad.classList.remove('hidden', 'print:hidden');
      contentModern.classList.add('hidden', 'print:hidden');
    }
  }
</script>

<style is:inline>
  body {
    /* https://developer.mozilla.org/en-US/docs/Web/CSS/print-color-adjust */
    print-color-adjust: exact;
  }
</style>

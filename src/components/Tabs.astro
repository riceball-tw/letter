---
interface TabItem {
  id: string;
  label: string;
  panelId: string;
}

interface Props {
  tabs: TabItem[];
  defaultTabId: string;
  tabKey?: string;
  rootClass?: string;
  hiddenPanelClasses?: string[];
  style?: string;
}

const {
  tabs,
  defaultTabId,
  tabKey = 'default',
  rootClass = '',
  hiddenPanelClasses = ['hidden'],
  style,
} = Astro.props as Props;
---

<div
  class={rootClass}
  style={style}
  data-tab-toggle
  data-tab-key={tabKey}
  data-hidden-panel-classes={hiddenPanelClasses.join(' ')}
>
  <div class="relative flex gap-2 rounded-full bg-primary-100 bg-opacity-90 p-1 shadow-sm backdrop-blur-md">
    <div
      class="tab-indicator absolute left-0 top-0 z-0 rounded-full bg-white shadow-sm transition-all duration-300 ease-[cubic-bezier(0.4,0,0.2,1)]"
    ></div>
    {tabs.map((tab) => {
      const isActive = tab.id === defaultTabId;

      return (
        <button
          type="button"
          id={`tab-${tab.id}`}
          class:list={[
            'resume-tab-btn relative z-10 cursor-pointer rounded-full px-6 py-2 text-sm font-medium transition-colors hover:text-primary-900',
            isActive ? 'text-primary-900' : 'text-primary-600',
          ]}
          data-tab-id={tab.id}
          data-panel-id={tab.panelId}
          aria-selected={isActive ? 'true' : 'false'}
        >
          {tab.label}
        </button>
      );
    })}
  </div>
</div>

<script is:inline>
  function init() {
    document.querySelectorAll('[data-tab-toggle]').forEach((root) => {
      if (root.dataset.initialized) return;
      root.dataset.initialized = 'true';

      const hiddenPanelClasses = root.dataset.hiddenPanelClasses?.split(' ').filter(Boolean) || ['hidden'];
      const tabKey = root.dataset.tabKey;
      const storageKey = `active-tab-${tabKey}`;
      const indicator = root.querySelector('.tab-indicator');

      function updateIndicator(btn) {
        if (!indicator || !btn) return;
        indicator.style.width = `${btn.offsetWidth}px`;
        indicator.style.height = `${btn.offsetHeight}px`;
        indicator.style.transform = `translate(${btn.offsetLeft}px, ${btn.offsetTop}px)`;
      }

      function applyTab(selectedId) {
        let activeBtn = null;

        root.querySelectorAll('button').forEach((btn) => {
          const isActive = btn.dataset.tabId === selectedId;
          
          btn.classList.toggle('text-primary-900', isActive);
          btn.classList.toggle('text-primary-600', !isActive);
          btn.setAttribute('aria-selected', isActive ? 'true' : 'false');

          if (isActive) {
            activeBtn = btn;
          }

          const panel = document.getElementById(btn.dataset.panelId);
          if (panel) hiddenPanelClasses.forEach(c => panel.classList.toggle(c, !isActive));
        });

        if (activeBtn) {
          updateIndicator(activeBtn);
        }
        localStorage.setItem(storageKey, selectedId);
      }

      // Initialize indicator position without animation initially
      if (indicator) {
        indicator.style.transition = 'none';
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            indicator.style.transition = '';
          });
        });
      }

      // Restore from localStorage
      const savedTabId = localStorage.getItem(storageKey);
      const defaultTabId = root.querySelector('[data-tab-id]')?.dataset.tabId;
      if (savedTabId && [...root.querySelectorAll('button')].some(b => b.dataset.tabId === savedTabId)) {
        applyTab(savedTabId);
      }

      root.querySelectorAll('button').forEach((button) => {
        button.addEventListener('click', () => {
          applyTab(button.dataset.tabId);
        });
      });
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>

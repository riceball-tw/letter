---
interface TabItem {
  id: string;
  label: string;
  panelId: string;
}

interface Props {
  tabs: TabItem[];
  defaultTabId: string;
  tabKey?: string;
  rootClass?: string;
  hiddenPanelClasses?: string[];
  style?: string;
}

const {
  tabs,
  defaultTabId,
  tabKey = 'default',
  rootClass = '',
  hiddenPanelClasses = ['hidden'],
  style,
} = Astro.props as Props;
const activeButtonClasses = ['bg-white', 'shadow-sm', 'text-primary-900'];
const inactiveButtonClasses = ['text-primary-600'];
---

<div
  class={rootClass}
  style={style}
  data-tab-toggle
  data-tab-key={tabKey}
  data-hidden-panel-classes={hiddenPanelClasses.join(' ')}
>
  <div class="flex gap-2 rounded-full bg-primary-100 bg-opacity-90 p-1 shadow-sm backdrop-blur-md">
    {tabs.map((tab) => {
      const isActive = tab.id === defaultTabId;

      return (
        <button
          type="button"
          id={`tab-${tab.id}`}
          class:list={[
            'resume-tab-btn cursor-pointer rounded-full px-6 py-2 text-sm font-medium transition-all hover:text-primary-900',
            isActive ? activeButtonClasses : inactiveButtonClasses,
          ]}
          data-tab-id={tab.id}
          data-panel-id={tab.panelId}
          aria-selected={isActive ? 'true' : 'false'}
        >
          {tab.label}
        </button>
      );
    })}
  </div>
</div>

<script is:inline>
  function init() {
    document.querySelectorAll('[data-tab-toggle]').forEach((root) => {
      if (root.dataset.initialized) return;
      root.dataset.initialized = 'true';

      const activeClasses = ['bg-white', 'shadow-sm', 'text-primary-900'];
      const inactiveClasses = ['text-primary-600'];
      const hiddenPanelClasses = root.dataset.hiddenPanelClasses?.split(' ').filter(Boolean) || ['hidden'];
      const storageKey = `active-tab-${root.dataset.tabKey}`;

      function applyTab(selectedId) {
        root.querySelectorAll('button').forEach((btn) => {
          const isActive = btn.dataset.tabId === selectedId;
          
          activeClasses.forEach(c => btn.classList.toggle(c, isActive));
          inactiveClasses.forEach(c => btn.classList.toggle(c, !isActive));
          btn.setAttribute('aria-selected', isActive ? 'true' : 'false');

          const panel = document.getElementById(btn.dataset.panelId);
          if (panel) hiddenPanelClasses.forEach(c => panel.classList.toggle(c, !isActive));
        });
        localStorage.setItem(storageKey, selectedId);
      }

      // Restore from localStorage
      const savedTabId = localStorage.getItem(storageKey);
      const defaultTabId = root.querySelector('[data-tab-id]')?.dataset.tabId;
      if (savedTabId && [...root.querySelectorAll('button')].some(b => b.dataset.tabId === savedTabId)) {
        applyTab(savedTabId);
      }

      root.querySelectorAll('button').forEach((button) => {
        button.addEventListener('click', () => {
          applyTab(button.dataset.tabId);
        });
      });
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
